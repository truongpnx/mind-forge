# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Required
POSTGRES_USER=mindforge
POSTGRES_PASSWORD=changeme

# Optional — defaults shown
POSTGRES_DB=db
POSTGRES_PORT=5432

# Optional — when set, takes priority over the individual fields above.
# Used by the app's config loader; do NOT set this for the postgres container.
# POSTGRES_CONNECTION_STRING=postgres://mindforge:changeme@localhost:5432/db?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional — defaults shown
REDIS_PORT=6379
REDIS_HOST=redis

# Optional — leave blank to run Redis without authentication
REDIS_USERNAME=
REDIS_PASSWORD=

# Optional — Unix socket path. Takes priority over host/port when non-empty.
# REDIS_SOCKET=/tmp/redis.sock
