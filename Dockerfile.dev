FROM golang:1.25-bookworm

WORKDIR /app

# Install envsubst (provided by gettext-base) for config template rendering
RUN apt-get update && apt-get install -y --no-install-recommends gettext-base && rm -rf /var/lib/apt/lists/*

# Install templ
RUN go install github.com/a-h/templ/cmd/templ@v0.3.1020

# Install air
RUN go install github.com/air-verse/air@v1.65.3

# Install tailwindcss standalone binary (v4)
RUN curl -sL https://github.com/tailwindlabs/tailwindcss/releases/download/v4.3.0/tailwindcss-linux-x64 \
    -o /usr/local/bin/tailwindcss \
    && chmod +x /usr/local/bin/tailwindcss

# Pre-download Go dependencies (cache layer)
COPY go.mod go.sum ./
RUN go mod download

COPY config/config.toml.tmpl /etc/mindforge/config.toml.tmpl
COPY scripts/entrypoint.server.sh /entrypoint.server.sh

# Populate config from template, then run CMD unchanged
ENTRYPOINT ["/entrypoint.server.sh"]

# Sleep indefinitely to keep the container running
CMD ["tail", "-f", "/dev/null"]